# ── Model ─────────────────────────────────────────────────────────────────────
# Local Ollama (default — free, no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ── Optional: swap to a cloud model ──────────────────────────────────────────
# Uncomment ONE block below and set CREW_MODEL_PROVIDER accordingly.

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# Groq (free tier available)
# GROQ_API_KEY=...
# GROQ_MODEL=llama3-8b-8192

# ── Paths (leave as defaults unless you move the data folder) ─────────────────
# DATA_DIR=data
# DOCS_DIR=data/docs
# CSV_FILE=data/complaints.csv
# REPORT_DIR=outputs/reports
# TRACE_DIR=outputs/traces
